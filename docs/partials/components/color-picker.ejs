    <section class="component">
      <h3 id="color-picker">Color Picker</h3>
      <div>
        <blockquote>
          The color picker input provides a small button showing the current color.
          Clicking it opens the browser's native color picker dialog.
          <footer>
            &mdash; Windows XP Color Picker Dialog
          </footer>
        </blockquote>

        <p>
          Use a standard <code>&lt;input type="color"&gt;</code> for a compact color picker button.
          It is styled to match XP buttons, with the selected color shown inside.
        </p>

        <%- example(`
          <section class="field-row">
            <label>Pick a color:</label>
            <input type="color" value="#0080FF">
          </section>
        `) %>

        <p>You can also place it alongside text inputs in a form.</p>

        <%- example(`
          <div class="field-row" style="align-items: center">
            <label>Background:</label>
            <input type="color" value="#FF8040">
            <input type="text" value="#FF8040" style="width: 80px">
          </div>
        `) %>

        <%- example(renderColorPickerDialog()) %>
      </div>
    </section>
